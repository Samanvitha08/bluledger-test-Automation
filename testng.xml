<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="BluLedger Suite" parallel="tests" thread-count="2">

    <listeners>
        <listener class-name="com.bluledgerautomation.listeners.TestListener"/>
        <listener class-name="com.bluledgerautomation.listeners.RetryListener"/>
    </listeners>

    <test name="Auth Tests">
        <classes>
            <class name="com.bluledgerautomation.tests.AuthTest"/>
        </classes>
    </test>

    <test name="Account Tests">
        <classes>
            <class name="com.bluledgerautomation.tests.AccountTest"/>
        </classes>
    </test>

    <test name="Transfer Tests">
        <classes>
            <class name="com.bluledgerautomation.tests.TransferTest"/>
        </classes>
    </test>

    <test name="Transaction Tests">
        <classes>
            <class name="com.bluledgerautomation.tests.TransactionTest"/>
        </classes>
    </test>

    <test name="Form Validation Tests">
        <classes>
            <class name="com.bluledgerautomation.tests.FormValidationTest"/>
        </classes>
    </test>

</suite>